# OTC Accounting SaaS — local environment template
# Copy this file to `.env.local` and fill in real values:
#   cp .env.example .env.local
# `.env.local` is gitignored; this template is safe to commit.
# Never commit real secrets. See README "Setup" for how to obtain each value.

# ---------------------------------------------------------------------------
# Supabase (Project Settings → Data API)
# ---------------------------------------------------------------------------
# Project URL, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public, client-safe key (formerly "anon" / "anon public").
# Both `publishable` and `anon` names work; prefer the new name going forward.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret. Bypasses RLS. Never expose to the browser.
# Used by route handlers that write via `update_extraction_result`.
SUPABASE_SERVICE_ROLE_KEY=

# The project ref (the `<ref>` in https://<ref>.supabase.co).
# Used by `npm run db:types` to generate `src/lib/database.types.ts`.
SUPABASE_PROJECT_REF=

# ---------------------------------------------------------------------------
# Google AI Studio (https://aistudio.google.com/apikey)
# ---------------------------------------------------------------------------
# API key for gemini-2.5-flash extractions.
GOOGLE_GENAI_API_KEY=

# ---------------------------------------------------------------------------
# Upstash QStash (https://console.upstash.com/qstash)
# ---------------------------------------------------------------------------
# Region base URL. QStash is region-sharded — token and signing keys below
# must match the region this URL points at.
#   EU (default):  https://qstash.upstash.io
#   US (us-east-1): https://qstash-us-east-1.upstash.io
# If unset, the @upstash/qstash SDK defaults to the EU endpoint.
QSTASH_URL=

# Bearer token for publishing jobs (region-specific).
QSTASH_TOKEN=

# Signing keys used to verify inbound QStash webhooks on /api/extract.
# Region-specific. Current is primary; next is rotated-in during key rolls.
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# When `false` (local dev only), the upload route invokes the extractor
# synchronously instead of publishing to QStash. Defaults to `true` in prod.
USE_QSTASH=true
