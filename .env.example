# OTC Accounting SaaS — local environment template
# Copy this file to `.env.local` and fill in real values:
#   cp .env.example .env.local
# `.env.local` is gitignored; this template is safe to commit.
# Never commit real secrets. See README "Setup" for how to obtain each value.

# ---------------------------------------------------------------------------
# Supabase (Project Settings → Data API)
# ---------------------------------------------------------------------------
# Project URL, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public, client-safe key (formerly "anon" / "anon public").
# Both `publishable` and `anon` names work; prefer the new name going forward.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret. Bypasses RLS. Never expose to the browser.
# Used by route handlers that write via `update_extraction_result`.
SUPABASE_SERVICE_ROLE_KEY=

# The project ref (the `<ref>` in https://<ref>.supabase.co).
# Used by `npm run db:types` to generate `src/lib/database.types.ts`.
SUPABASE_PROJECT_REF=

# ---------------------------------------------------------------------------
# Google AI Studio (https://aistudio.google.com/apikey)
# ---------------------------------------------------------------------------
# API key. Must be on a project with gemini-3-flash-preview access enabled.
GOOGLE_GENAI_API_KEY=

# Model ID for extractions. Default is `gemini-3-flash-preview`.
# If the preview model is retired, flip to `gemini-2.5-flash` (no code change).
GEMINI_MODEL=gemini-3-flash-preview

# ---------------------------------------------------------------------------
# Upstash QStash (https://console.upstash.com/qstash)
# ---------------------------------------------------------------------------
# Base URL. Leave unset in production to use the cloud default (EU endpoint).
# Regional alternates:
#   US: https://qstash-us-east-1.upstash.io
# Local dev: run `npx @upstash/qstash-cli@latest dev` and set this to the
# local URL the CLI prints (typically http://localhost:8080). The CLI also
# prints values for the token and signing keys below — paste those in.
QSTASH_URL=

# Bearer token for publishing jobs. Production: region-specific from the
# Upstash dashboard. Local dev: value printed by `qstash-cli dev`.
QSTASH_TOKEN=

# Signing keys used to verify inbound QStash webhooks on /api/extract.
# Production: region-specific from the Upstash dashboard (current is primary;
# next is rotated-in during key rolls). Local dev: values printed by
# `qstash-cli dev`.
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ---------------------------------------------------------------------------
# Site URL (optional for local dev; required in production)
# ---------------------------------------------------------------------------
# Canonical origin used to build OAuth redirectTo URLs. When unset, the app
# falls back to VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL on Vercel, and to
# window.location.origin in the browser for local dev.
# Production: set to the apex domain, e.g. https://otc-accounting.example.com.
NEXT_PUBLIC_SITE_URL=

# ---------------------------------------------------------------------------
# OAuth providers (optional; omit to disable the corresponding button)
# ---------------------------------------------------------------------------
# Set values in .env.local for local dev. For production, set the same values
# in the Supabase Dashboard (Authentication → Providers). See
# docs/solutions/best-practices/oauth-google-microsoft-supabase-setup-2026-04-24.md
# for the provider-app creation runbook.

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 client ID.
# Authorized redirect URI on Google's side must be `${NEXT_PUBLIC_SUPABASE_URL}/auth/v1/callback`.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Azure portal → App registrations → your app. Same redirect-URI rule as above.
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_AZURE_SECRET=
# Tenant URL. Default accepts both personal and work/school accounts.
# Single-tenant: https://login.microsoftonline.com/<TENANT-ID>/v2.0
SUPABASE_AUTH_EXTERNAL_AZURE_URL=https://login.microsoftonline.com/common/v2.0
